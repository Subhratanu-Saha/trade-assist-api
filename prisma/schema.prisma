generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model agent {
  userid    String    @id @map("    userid") @db.VarChar(40)
  name      String    @map("    name") @db.VarChar(100)
  dob       DateTime? @map("    dob") @db.Date
  password  String    @map("    password") @db.VarChar(255)
  email_id  String    @unique @map("    email_id") @db.VarChar(150)
  ad_groups String[]  @map("    ad_groups")

  @@map("agent")
}

model customer {
  customerid        String     @id @map("    customerid") @db.VarChar(40)
  name              String     @map("    name") @db.VarChar(100)
  emailaddr         String     @unique @map("    emailaddr") @db.VarChar(150)
  contactnum        String?    @map("    contactnum") @db.VarChar(15)
  dob               DateTime?  @map("    dob") @db.Date
  gender            String?    @map("    gender") @db.VarChar(1)
  address           String?    @map("    address")
  isactive          Boolean?   @default(true) @map("    isactive")
  sysonboarddt      DateTime?  @map("    sysonboarddt") @db.Timestamp(6)
  syslastmodifieddt DateTime?  @default(now()) @map("    syslastmodifieddt") @db.Timestamp(6)
  purchase          purchase[]
}

model purchase {
  purchaseid    String    @id @db.VarChar(40)
  productitem   String    @db.VarChar(200)
  transactionid String    @unique @db.VarChar(100)
  purchasedt    DateTime? @default(now()) @db.Timestamp(6)
  customerid    String    @db.VarChar(40)
  payment       Decimal?  @db.Decimal(10, 2)
  customer      customer  @relation(fields: [customerid], references: [customerid], onDelete: NoAction, onUpdate: NoAction, map: "fk_purchase_customer")
}
